# Data root directory: the default monitored path used when the web page initializes
DATA_ROOT=/path/to/your/raw_data

# Persistent cache directory
CACHE_DIR=../../../../.cache

# Temporary directory for generated submit configs
SUBMIT_CONFIG_DIR=../../../../.submit_configs

# Default remote upload json config used by the web UI
REMOTE_UPLOAD_CONFIG_PATH=../../../../remote_upload_hosts.example.json

# Optional patch file path applied when initializing the submit config
SUBMIT_CONFIG_PATCH_PATH=/path/to/your/submit_config_patch.json

# Whether to clear proxy environment variables before submitting jobs, to avoid inheriting VS Code or terminal proxy settings in RoboOrchardJob-AIDISubmit
SUBMIT_JOB_CLEAR_PROXY=true

# Robo Orchard Lab root directory (must contain dataset/horizon_manipulation/tools/submit_*.json)
ROBO_ORCHARD_LAB_DIR=../../../../robo_orchard_lab

# Service
HOST=0.0.0.0
PORT=12000
FLASK_DEBUG=false
