      "remote_venv_activate": "/home/user/workspace/venv/robot-env/bin/activate"
    },
    {
      "name": "gpu_server_2",
      "host": "10.0.0.12",
      "input_path": "/data",
      "ssh_user": "user",
      "remote_venv_activate": "/home/user/workspace/venv/robot-env/bin/activate"
    },
    {
      "name": "robot_host_1",
      "host": "10.0.0.21",
      "input_path": "/home/user/data/holobrain",
      "ssh_user": "user",
      "remote_venv_activate": "/home/user/workspace/venv/robot-env/bin/activate"
    }
  ]
}
