{
    "job_name": "eval_geniesim3_holobrain",
    "workspace_folder": "submit/holobrain",
    "docker_image": "hub.hobot.cc/auto/robot_lab/jiawei03.li/geniesim_holobrain:0.5.7",
    "input_bucket": "robot_lab,robot_lab2",
    "output_bucket": "robot_lab,robot_lab2",
    "num_workers": 4,
    "gpu_per_worker": 2,
    "wall_time": 14400,
    "cmd": [
        "export HOLOBRAIN_MODEL_DIR=http://pfs-svcspawner.bcloud-bj-zone1.hobot.cc/user/homespace/xuewu.lin-labs/plat_gpu/2026-05-26/12-34/bcloud-bj-zone1-e3b7b3b7de28/holobrain_geniesim_depth_noise_39350ef8_58bc_11f1_9bdf_1d433b603abb/output/checkpoints/checkpoint_22",
        "export EVAL_TASK_NAMES=icra_open_door,icra_place_block_into_box,icra_pour_workpiece,icra_take_wrong_item_shelf,icra_sorting_packages_continuous,icra_sorting_packages,icra_bimanual_hold_pot,icra_stock_and_straighten_shelf",
        "export SIM_ASSETS=/horizon-bucket/robot_lab2/users/jiawei03.li-labs/data/GenieSimAssets",
        "export WORKSPACE_DIR=/job_data",
        "export GENIESIM_DIR=${WORKSPACE_DIR}/geniesim3_eval",
        "export HOLOBRAIN_DIR=${GENIESIM_DIR}/holobrain_logs",
        "worker_rank=$(sed -nE 's/.*--machine_rank ([0-9]+).*/\\1/p' rank 2>/dev/null)",
        "worker_rank=${worker_rank:-0}",
        "worker_num=${WORKER_NUM:-1}",
        "infer_host=127.0.0.1",
        "infer_port=$((8999 + worker_rank))",
        "echo worker_rank=${worker_rank} worker_num=${worker_num} infer_host=${infer_host}:${infer_port}",
        "mkdir -p ${HOLOBRAIN_DIR}",
        "ln -sfn /horizon-bucket/robot_lab/users/xuewu.lin/ckpt ckpt",
        "ln -sfn /horizon-bucket/robot_lab/users/xuewu.lin/urdf urdf",
        "export PYTHONPATH=${WORKING_PATH}:$PYTHONPATH",
        "export PATH=/opt/holobrain/bin:${PATH}",
        "HOLOBRAIN_LOG_FILE=${HOLOBRAIN_DIR}/holobrain_inference_server_worker_${worker_rank}_of_${worker_num}.log",
        "HOLOBRAIN_PID_FILE=${HOLOBRAIN_LOG_FILE%.log}.pid",
        "CUDA_VISIBLE_DEVICES=1 nohup python3 geniesim3_inference_server.py \\",
        "  --model_dir ${HOLOBRAIN_MODEL_DIR} \\",
        "  --model_processor agibot_geniesim3_challenge_processor \\",
        "  --model_prefix model \\",
        "  --host \"${infer_host}\" \\",
        "  --port \"${infer_port}\" \\",
        "  --use_depth true \\",
        "  > ${HOLOBRAIN_LOG_FILE} 2>&1 &",
        "echo $! > ${HOLOBRAIN_PID_FILE}",
        "/geniesim/main/scripts/wait_holobrain_start_infer.sh ${HOLOBRAIN_LOG_FILE} ${HOLOBRAIN_PID_FILE}",
        "/geniesim/main/scripts/start_geniesim3_eval.sh \\",
        "  --infer-host \"${infer_host}:${infer_port}\" \\",
        "  --worker-rank \"${worker_rank}\" \\",
        "  --worker-num \"${worker_num}\" \\",
        "  --output-dir \"${GENIESIM_DIR}\" \\",
        "  --task-names \"${EVAL_TASK_NAMES}\""
    ],
    "to_upload": [
        "robo_orchard_lab",
        "projects/holobrain_internal/common/holobrain_utils.py",
        "projects/holobrain_internal/common/geniesim3_inference_server.py",
        "projects/holobrain_internal/common/holobrain_geniesim3_policy"
    ],
    "job_password": "1227",
    "queue_name": "project-5090-robot-lab-bcloud-bj",
    "project_id": "horizon-labs"
}
