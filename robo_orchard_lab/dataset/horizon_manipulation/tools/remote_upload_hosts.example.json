{
  "defaults": {
    "remote_python": "python3",
    "output_path": "/horizon-bucket/robot_lab/users/<user>/agx_data",
    "user_names": "user_a,user_b",
    "task_names": "task_a,task_b,task_c",
    "date_prefix": "2026_03_25,2026_03_26",
    "num_workers": 32,
    "connect_timeout": 10,
    "token": "<aidi-token>"
  },
  "hosts": [
    {
