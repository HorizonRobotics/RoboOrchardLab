{
    "job_name": "eval_behavior1k_holobrain",
    "workspace_folder": "submit-holobrain",
    "docker_image": "hub.hobot.cc/auto/robot_lab_base:ubuntu2204-gcc114-py310-cu128-torch270-b1k-v2.3.1",
    "input_bucket": "robot_lab,robot_lab2",
    "output_bucket": "robot_lab,robot_lab2",
    "num_workers": 1,
    "gpu_per_worker": 2,
    "wall_time": 14400,
    "cmd": [
        "set -x",
        "ln -s /horizon-bucket/robot_lab2/users/qingze.wang/urdf ${WORKING_PATH}/urdf",
        "ln -s /horizon-bucket/robot_lab2/users/qingze.wang/ckpt ${WORKING_PATH}/ckpt",
        "find /horizon-bucket/robot_lab2/users/qingze.wang/codebase/BEHAVIOR-1K_main -maxdepth 1 -mindepth 1 -type d -exec ln -s {} ${WORKING_PATH} \\;",
        "cp behavior1k/eval_b1k.py OmniGibson/omnigibson/learning",
        "cp behavior1k/tasks.yaml OmniGibson/omnigibson/learning/configs/",
        "cp behavior1k/rgbd_obs_wrapper.py OmniGibson/omnigibson/learning/wrappers",
        "cp holobrain_behavior1k_policy/deploy_policy.py OmniGibson/omnigibson/learning/",

        "export PYTHONPATH=${WORKING_PATH}/OmniGibson:$PYTHONPATH",
        "export PYTHONPATH=${WORKING_PATH}/bddl3/:$PYTHONPATH",
        "export PYTHONPATH=${WORKING_PATH}/joylo:$PYTHONPATH",
        "export PYTHONPATH=${WORKING_PATH}/robo_orchard_lab:$PYTHONPATH",
        "export OMNIGIBSON_DATA_PATH=${WORKING_PATH}/datasets",
        "export TORCHDYNAMO_DISABLE=1",

        "export WORLD_SIZE=$VC_TASK_NUM",
        "export RANK=$(sed -nE 's/.*--machine_rank ([0-9]+).*/\\1/p' rank)",
        "export MASTER_ADDR=$(echo $VC_TASK_HOSTS | cut -d',' -f1)",
        "export MASTER_PORT=29500",

        "source /App/miniconda3/etc/profile.d/conda.sh",
        "conda activate behavior",

        "python3 behavior1k_eval.py \\",
        "   --model_path http://pfs-svcspawner.bcloud-bj-zone1.hobot.cc/user/homespace/qingze.wang-labs/plat_gpu/2026-03-18/10-15/bcloud-bj-zone1-920590a4a474/output/checkpoints/checkpoint_8/ \\",
        "   --model_processor behavior1k_processor \\",
        "   --model_prefix model \\",
        "   --vlm_ckpt_dir /horizon-bucket/robot_lab2/users/qingze.wang/ckpt \\",
        "   --urdf_dir /horizon-bucket/robot_lab2/users/qingze.wang/urdf \\",
        "   --task_names picking_up_trash \\",
        "   --instance_per_job 5 "
    ],
    "to_upload": [
        "robo_orchard_lab",
        "projects/holobrain_internal/behavior1k",
        "projects/holobrain_internal/common/behavior1k_eval.py",
        "projects/holobrain_internal/common/holobrain_behavior1k_policy"
    ],
    "job_password": "123456",
    "queue_name": "project-5090-robot-lab-bcloud-bj",
    "project_id": "horizon-labs"
}
