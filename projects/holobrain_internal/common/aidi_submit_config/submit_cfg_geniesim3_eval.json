    "num_workers": 1,
    "gpu_per_worker": 2,
    "wall_time": 14400,
    "cmd": [
        "export HOLOBRAIN_MODEL_DIR=http://pfs-svcspawner.bcloud-bj-zone1.hobot.cc/user/homespace/jiawei03.li-labs/plat_gpu/2026-05-20/14-12/bcloud-bj-zone1-9b1e995a1788/holobrain_geniesim3_e0cad0a2_5412_11f1_8925_be3af2b6059f/output/checkpoints/checkpoint_20",
        "export HOLOBRAIN_INFER_HOST=127.0.0.1",
        "export HOLOBRAIN_INFER_PORT=8999",
        "export HOLOBRAIN_LOG_DIR=/job_data/holobrain_infer/logs",
        "export PYTHONPATH=${WORKING_PATH}:$PYTHONPATH",
        "export SIM_ASSETS=/horizon-bucket/robot_lab2/users/jiawei03.li-labs/data/GenieSimAssets",
        "ln -sfn /horizon-bucket/robot_lab/users/xuewu.lin/ckpt ckpt",
        "ln -sfn /horizon-bucket/robot_lab/users/xuewu.lin/urdf urdf",
        "mkdir -p ${HOLOBRAIN_LOG_DIR}",
        "CUDA_VISIBLE_DEVICES=1 nohup /opt/holobrain/bin/holobrain_python \\",
        "  ${WORKING_PATH}/geniesim3_inference_server.py \\",
        "  --model_dir ${HOLOBRAIN_MODEL_DIR} \\",
        "  --model_processor agibot_geniesim3_challenge_processor \\",
        "  --model_prefix model \\",
        "  --host ${HOLOBRAIN_INFER_HOST} \\",
        "  --port ${HOLOBRAIN_INFER_PORT} \\",
        "  --use_depth false \\",
        "  > ${HOLOBRAIN_LOG_DIR}/geniesim3_inference_server.log 2>&1 &",
        "echo $! > ${HOLOBRAIN_LOG_DIR}/geniesim3_inference_server.pid",
        "/opt/holobrain/bin/holobrain_geniesim3_start_infer",
        ". /opt/holobrain/bin/geniesim3_source_eval_env.sh",
        "/opt/holobrain/bin/geniesim3_prepare_icra_configs",
        "cd /geniesim/main",
        "bash ./scripts/run_icra_tasks.sh --record-output-dir /job_data/geniesim3_eval_record_videos"
